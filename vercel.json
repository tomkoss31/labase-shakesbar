{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/jeu", "destination": "/jeu.html" },
    { "source": "/console", "destination": "/console.html" }
  ],
  "crons": [
    {
      "path": "/api/cron?type=birthday",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron?type=relance",
      "schedule": "0 18 * * *"
    }
  ]
}
